# Provider: "openai" or "lmstudio"
PROVIDER=openai

# === OpenAI-compatible (fallback) ===
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# === Flash model (cheap, default) ===
FLASH_MODEL=deepseek-v4-flash
# FLASH_API_KEY=
# FLASH_BASE_URL=

# === Pro model (powerful, use via /pro) ===
PRO_MODEL=deepseek-v4-pro
# PRO_API_KEY=
# PRO_BASE_URL=

# === Model routing ===
# Auto-downgrade to flash during peak hours (9:00-12:00, 14:00-18:00)
AUTO_DOWNGRADE_ON_PEAK=true
# Default model on startup: "flash" or "pro"
DEFAULT_MODEL=flash

# === Session ===
# Directory for session logs (relative to project root)
LOG_DIR=.dekacode/logs
# Max session cost in yuan (0 = unlimited)
MAX_SESSION_COST=0.0

# === LMStudio (local, alternative provider) ===
# PROVIDER=lmstudio
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LMSTUDIO_MODEL=local-model
