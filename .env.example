# Provider: "openai" or "lmstudio"
PROVIDER=openai

# === OpenAI-compatible (fallback) ===
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# === Flash model (cheap, default) ===
FLASH_MODEL=deepseek-v4-flash
# FLASH_API_KEY=
# FLASH_BASE_URL=

# === Pro model (powerful, use via /pro) ===
PRO_MODEL=deepseek-v4-pro
# PRO_API_KEY=
# PRO_BASE_URL=

# === Model routing ===
# Auto-downgrade to flash during peak hours (9:00-12:00, 14:00-18:00)
AUTO_DOWNGRADE_ON_PEAK=true
# Default model on startup: "flash" or "pro"
DEFAULT_MODEL=flash

# === Session ===
# Directory for session logs (relative to project root)
LOG_DIR=.dekacode/logs
# Max session cost in yuan (0 = unlimited)
MAX_SESSION_COST=0.0
# Max tool call iterations per turn (0 = default loop, large number = practically unlimited)
# MAX_TOOL_ITERATIONS=999999

# === Call Graph ===
# Max directory depth for recursive file scanning (-1 = unlimited)
# MAX_DEPTH=-1

# === GitHub ===
# GitHub Personal Access Token (repo scope for private repos)
# GITHUB_TOKEN=
# GITHUB_BASE_URL=https://api.github.com

# === Mnemosyne Memory System ===
# Enable Mnemosyne memory layer (auto-store/recall conversation context)
MNEMOSYNE_ENABLED=true
# Memory bank name (for per-project isolation)
# MNEMOSYNE_BANK=dekacode
# Embedding model (default: BAAI/bge-small-en-v1.5)
# MNEMOSYNE_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Data directory (default: ~/.hermes/mnemosyne/data)
# MNEMOSYNE_DATA_DIR=

# === LMStudio (local, alternative provider) ===
# PROVIDER=lmstudio
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LMSTUDIO_MODEL=local-model

# === WebUI ===
# Default collapse state for thinking details panel
# THINKING_COLLAPSED_DEFAULT=true
